{
  "expo": {
    "name": "FinTech App",
    "slug": "fintech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0E21"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fintechapp.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fintechapp.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A0E21"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },
    "extra": {
      "eas": {
        "projectId": "3631d8a8-0205-4c7a-8989-054225eb9ea6"
      }
    }
  }
}
